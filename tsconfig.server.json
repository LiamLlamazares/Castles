{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "ignoreDeprecations": "6.0",
    "isolatedModules": false,
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "server-build",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["server/index.ts"]
}
