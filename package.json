{
  "name": "chess-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.21.0"
  },
  "scripts": {
    "start": "vite --host localhost --port 3000",
    "dev": "vite --host localhost --port 3000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host localhost --port 3000",
    "server:dev": "tsx server/index.ts",
    "server:build": "tsc -p tsconfig.server.json",
    "server:check-config": "node server-build/server/check-config.js",
    "server:start": "node server-build/server/index.js",
    "online:smoke:local:preflight": "node scripts/deploy/check-local-postgres-prereqs.mjs",
    "online:smoke:local": "node scripts/deploy/check-local-online-restart-smoke.mjs",
    "online:smoke:local:concurrency": "node scripts/deploy/check-local-postgres-concurrency-smoke.mjs",
    "online:smoke:local:load": "node scripts/deploy/check-local-postgres-load-smoke.mjs",
    "online:smoke:local:runtime-nodes": "node scripts/deploy/check-local-postgres-runtime-nodes-smoke.mjs",
    "online:smoke:local:challenges": "node scripts/deploy/check-local-postgres-challenge-smoke.mjs",
    "online:smoke:local:browser": "node scripts/deploy/check-local-online-browser-smoke.mjs",
    "online:backup:postgres": "node scripts/deploy/postgres-online-backup.mjs",
    "online:restore:postgres:drill": "node scripts/deploy/postgres-online-restore-drill.mjs",
    "online:deploy:metadata": "node scripts/deploy/deploy-metadata-env.mjs",
    "online:deploy:production": "node scripts/deploy/deploy-production.mjs",
    "online:deploy:production:dry-run": "node scripts/deploy/deploy-production.mjs --dry-run",
    "online:deploy:freshness": "node scripts/deploy/check-production-freshness.mjs",
    "online:monitor:production": "node scripts/deploy/check-production-monitoring.mjs",
    "online:demo:rated": "node scripts/deploy/create-rated-demo-games.mjs",
    "online:smoke:browser": "node scripts/deploy/check-online-browser-smoke.mjs",
    "ui:audit:local": "node scripts/deploy/check-local-ui-layout-audit.mjs",
    "assets:favicon": "tsx scripts/assets/generate-empty-board-favicon.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=low"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
