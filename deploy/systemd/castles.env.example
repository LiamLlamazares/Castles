NODE_ENV=production
PORT=3000
CASTLES_BIND_HOST=127.0.0.1
PUBLIC_BASE_URL=https://castles.ls314.com
ONLINE_STORE_BACKEND=postgres
DATABASE_URL=postgresql://castles:replace-with-password@postgres-host.example:5432/castles
POSTGRES_POOL_MAX_PER_STORE=5
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/api/online/account/oauth/google/callback when unset.
GOOGLE_OAUTH_REDIRECT_URI=
CASTLES_STATIC_DIR=/home/lukasz/Castles/build
CASTLES_REQUIRE_STATIC_DIR=1
BUILD_ID=replace-with-build-id
GIT_COMMIT=replace-with-deployed-sha
